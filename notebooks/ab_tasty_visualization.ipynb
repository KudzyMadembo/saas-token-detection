 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# AB Tasty Visualization Walkthrough\n",
    "\n",
    "This notebook loads normalized logs and pipeline alerts, then shows presentation-ready views for:\n",
    "\n",
    "- low vs medium vs high logs\n",
    "- pipeline anomaly windows\n",
    "- raw-rule anomaly windows\n",
    "- top suspicious entities"
   ]
  },
  {
   "cell_type": "python",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from pathlib import Path\n",
    "import sys\n",
    "\n",
    "import pandas as pd\n",
    "import plotly.express as px\n",
    "\n",
    "root = Path.cwd().resolve().parent\n",
    "if str(root) not in sys.path:\n",
    "    sys.path.insert(0, str(root))\n",
    "\n",
    "from visualization.data_prep import prepare_visualization_datasets"
   ]
  },
  {
   "cell_type": "python",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "datasets = prepare_visualization_datasets()\n",
    "datasets['summary']"
   ]
  },
  {
   "cell_type": "python",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "daily = datasets['daily_counts']\n",
    "timeline = daily.melt(\n",
    "    id_vars=['date'],\n",
    "    value_vars=['low_logs', 'medium_logs', 'high_logs'],\n",
    "    var_name='severity',\n",
    "    value_name='log_count',\n",
    ")\n",
    "timeline['severity'] = timeline['severity'].str.replace('_logs', '', regex=False)\n",
    "fig = px.bar(timeline, x='date', y='log_count', color='severity', barmode='stack', title='Low vs Medium vs High Logs by Day')\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "python",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "pipeline = datasets['pipeline_anomalies']\n",
    "raw_rules = datasets['raw_rule_anomalies']\n",
    "\n",
    "pipeline_daily = (\n",
    "    pipeline.groupby('date', as_index=False).size().rename(columns={'size': 'pipeline_windows'})\n",
    "    if not pipeline.empty\n",
    "    else pd.DataFrame(columns=['date', 'pipeline_windows'])\n",
    ")\n",
    "raw_daily = (\n",
    "    raw_rules.groupby('date', as_index=False).size().rename(columns={'size': 'raw_rule_windows'})\n",
    "    if not raw_rules.empty\n",
    "    else pd.DataFrame(columns=['date', 'raw_rule_windows'])\n",
    ")\n",
    "windows = pipeline_daily.merge(raw_daily, on='date', how='outer').fillna(0)\n",
    "windows = windows.sort_values('date')\n",
    "windows_long = windows.melt(id_vars=['date'], value_vars=['pipeline_windows', 'raw_rule_windows'], var_name='source', value_name='window_count')\n",
    "fig = px.line(windows_long, x='date', y='window_count', color='source', markers=True, title='Anomaly Windows by Source')\n",
    "fig.show()"
   ]
  },
  {
   "cell_type": "python",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "datasets['top_severity_endpoints'].head(10)"
   ]
  },
  {
   "cell_type": "python",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "datasets['labeled_events'][datasets['labeled_events']['event_severity'].isin(['low','medium','high'])][['event_time','tenant_id','token_id','endpoint','geo_country','event_severity']].head(20)"
   ]
  }
